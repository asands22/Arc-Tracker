<script>
var CHANNELS = ["Spatial","Verbal","Environmental","Internal"];
var PROFILES  = ["Reactive","Rigid","Avoidant","Passive","Imp. Reactive","Imp. Rigid","Imp. Avoidant","Imp. Passive","Attuned"];

var DB = { dogs: [] };
var editingId = null;
var detailId  = null;
var sessionTargetId = null;

// ── STORAGE ──────────────────────────────────────────────────────────────
function storageSet(key, val) {
  var str = JSON.stringify(val);
  var ok = false;
  // Try window.storage first (Claude app)
  if (window.storage && typeof window.storage.set === "function") {
    try { window.storage.set(key, str); ok = true; } catch(e) {}
  }
  // Always also write localStorage (browser fallback)
  try { localStorage.setItem(key, str); ok = true; } catch(e) {}
  return ok;
}

function storageGet(key) {
  // Try window.storage first
  if (window.storage && typeof window.storage.get === "function") {
    try {
      var r = window.storage.get(key);
      // window.storage.get may be async — handle both
      if (r && typeof r.then === "function") {
        // async path handled separately
      } else if (r && r.value) {
        return JSON.parse(r.value);
      }
    } catch(e) {}
  }
  // Fallback to localStorage
  try {
    var raw = localStorage.getItem(key);
    if (raw) return JSON.parse(raw);
  } catch(e) {}
  return null;
}

async function loadDB() {
  var modeLabel = document.getElementById("storage-mode-label");
  var loaded = false;

  // Try window.storage async first
  if (window.storage && typeof window.storage.get === "function") {
    try {
      var r = await window.storage.get("shdt-dog-log");
      if (r && r.value) {
        DB = JSON.parse(r.value);
        loaded = true;
        if (modeLabel) modeLabel.textContent = "window.storage (Claude app)";
      }
    } catch(e) {}
  }

  // If not found, try localStorage
  if (!loaded) {
    try {
      var raw = localStorage.getItem("shdt-dog-log");
      if (raw) { DB = JSON.parse(raw); loaded = true; }
      if (modeLabel) modeLabel.textContent = "localStorage (browser)";
    } catch(e) {}
  }

  if (!DB.dogs) DB.dogs = [];
  renderDashboard();
}

function saveDB() {
  // Write to both
  var str = JSON.stringify(DB);
  if (window.storage && typeof window.storage.set === "function") {
    try { window.storage.set("shdt-dog-log", str); } catch(e) {}
  }
  try { localStorage.setItem("shdt-dog-log", str); } catch(e) {}
}

// ── PANEL TOGGLE ─────────────────────────────────────────────────────────
function togglePanel(header) {
  var isOpen = header.classList.contains("open");
  var bodyId = "pb-" + header.id.replace("ph-","");
  var body = document.getElementById(bodyId);
  var chev = header.querySelector(".chevron");
  if (isOpen) {
    header.classList.remove("open");
    body.classList.remove("open");
    chev.classList.remove("open");
  } else {
    header.classList.add("open");
    body.classList.add("open");
    chev.classList.add("open");
  }
}

// ── RENDER DASHBOARD ────────────────────────────────────────────────────
function renderDashboard() {
  renderStats();
  renderDogGrid();
  renderPatterns();
  renderMatchRatio();
}

function renderStats() {
  var dogs = DB.dogs;
  document.getElementById("stat-total").textContent = dogs.length;

  // distinct profiles
  var profs = {};
  dogs.forEach(function(d) { if (d.profile) profs[d.profile] = 1; });
  document.getElementById("stat-profiles").textContent = Object.keys(profs).length || "—";

  // top breed
  var breeds = {};
  dogs.forEach(function(d) { if (d.breed) breeds[d.breed] = (breeds[d.breed]||0)+1; });
  var topBreed = Object.keys(breeds).sort(function(a,b){return breeds[b]-breeds[a];})[0] || "—";
  document.getElementById("stat-breed").textContent = topBreed;

  // avg match score
  var scores = dogs.filter(function(d){return d.matchScore;}).map(function(d){return parseFloat(d.matchScore);});
  if (scores.length) {
    var avg = (scores.reduce(function(a,b){return a+b;},0)/scores.length).toFixed(1);
    document.getElementById("stat-match").textContent = avg;
  } else {
    document.getElementById("stat-match").textContent = "—";
  }

  // top dominant channel
  var chs = {};
  dogs.forEach(function(d){ if (d.dominant) chs[d.dominant]=(chs[d.dominant]||0)+1; });
  var topCh = Object.keys(chs).sort(function(a,b){return chs[b]-chs[a];})[0] || "—";
  document.getElementById("stat-channel").textContent = topCh;

  document.getElementById("dog-count").textContent = dogs.length;
}

function renderDogGrid() {
  var container = document.getElementById("dog-grid-container");
  if (!DB.dogs.length) {
    container.innerHTML = '<div class="empty"><div class="empty-icon">&#9670;</div><div class="empty-title">No dogs logged yet</div><div class="empty-sub">Hit "+ New Dog" to start building the intelligence base</div></div>';
    return;
  }
  var html = '<div class="dog-grid">';
  DB.dogs.forEach(function(d) {
    html += '<div class="dog-card" onclick="showDetail(\''+d.id+'\')">';
    html += '<div class="dog-name">'+esc(d.name||"Unnamed")+'</div>';
    if (d.breed) html += '<div class="dog-breed">'+esc(d.breed)+(d.age?' &middot; '+esc(d.age):'')+'</div>';
    html += '<div class="dog-tags">';
    if (d.dominant) html += '<span class="tag tag-channel">'+esc(d.dominant)+'</span>';
    if (d.profile)  html += '<span class="tag tag-profile">'+esc(d.profile)+'</span>';
    if (d.matchScore) {
      var sc = parseFloat(d.matchScore);
      var cls = sc >= 7 ? "tag-match" : sc <= 4 ? "tag-risk" : "tag-channel";
      html += '<span class="tag '+cls+'">Match '+esc(d.matchScore)+'/10</span>';
    }
    html += '</div>';
    if (d.handler) html += '<div class="dog-handler">Handler: '+esc(d.handler)+'</div>';
    html += '</div>';
  });
  html += '</div>';
  container.innerHTML = html;
}

function renderPatterns() {
  var inner = document.getElementById("pattern-inner");
  var dogs = DB.dogs;
  if (dogs.length < 2) {
    inner.innerHTML = '<div class="empty"><div class="empty-title">Not enough data yet</div><div class="empty-sub">Add more dogs to surface patterns</div></div>';
    return;
  }

  // Profile → breeds
  var profileBreeds = {};
  dogs.forEach(function(d) {
    if (!d.profile || !d.breed) return;
    if (!profileBreeds[d.profile]) profileBreeds[d.profile] = {};
    profileBreeds[d.profile][d.breed] = (profileBreeds[d.profile][d.breed]||0)+1;
  });

  // Dominant channel → blind channel
  var sigPairs = {};
  dogs.forEach(function(d) {
    if (!d.dominant || !d.blind) return;
    var key = d.dominant + " → blind: " + d.blind;
    sigPairs[key] = (sigPairs[key]||0)+1;
  });

  var html = "";

  if (Object.keys(profileBreeds).length) {
    html += '<div style="margin-bottom:24px">';
    html += '<div class="form-section-title" style="margin-bottom:12px">Profile → Common Breed Choices</div>';
    html += '<table class="pattern-table"><thead><tr><th>Handler Profile</th><th>Top Breed Choice</th><th>Count</th></tr></thead><tbody>';
    Object.keys(profileBreeds).forEach(function(prof) {
      var bs = profileBreeds[prof];
      var topB = Object.keys(bs).sort(function(a,b){return bs[b]-bs[a];})[0];
      html += '<tr><td><span class="tag tag-profile">'+esc(prof)+'</span></td><td style="color:var(--cream)">'+esc(topB)+'</td><td style="color:var(--muted)">'+bs[topB]+'</td></tr>';
    });
    html += '</tbody></table></div>';
  }

  if (Object.keys(sigPairs).length) {
    html += '<div>';
    html += '<div class="form-section-title" style="margin-bottom:12px">Signature Patterns</div>';
    html += '<table class="pattern-table"><thead><tr><th>Dominant → Blind</th><th>Frequency</th></tr></thead><tbody>';
    Object.keys(sigPairs).sort(function(a,b){return sigPairs[b]-sigPairs[a];}).forEach(function(k) {
      html += '<tr><td style="color:var(--cream)">'+esc(k)+'</td><td style="color:var(--muted)">'+sigPairs[k]+'</td></tr>';
    });
    html += '</tbody></table></div>';
  }

  if (!html) html = '<div class="empty"><div class="empty-title">Add profile and breed data to see patterns</div></div>';
  inner.innerHTML = html;
}

function renderMatchRatio() {
  var inner = document.getElementById("match-inner");
  var dogs = DB.dogs.filter(function(d){return d.profile && d.matchScore;});
  if (!dogs.length) {
    inner.innerHTML = '<div class="empty"><div class="empty-title">No match score data yet</div></div>';
    return;
  }

  var profileScores = {};
  dogs.forEach(function(d) {
    if (!profileScores[d.profile]) profileScores[d.profile] = [];
    profileScores[d.profile].push(parseFloat(d.matchScore));
  });

  var html = '<table class="pattern-table"><thead><tr><th>Profile</th><th>Avg Match Score</th><th>Dogs</th></tr></thead><tbody>';
  Object.keys(profileScores).sort().forEach(function(prof) {
    var arr = profileScores[prof];
    var avg = (arr.reduce(function(a,b){return a+b;},0)/arr.length);
    var pct = (avg/10*100).toFixed(0);
    html += '<tr><td><span class="tag tag-profile">'+esc(prof)+'</span></td>';
    html += '<td><div class="match-bar-wrap"><div class="match-bar-bg"><div class="match-bar-fill" style="width:'+pct+'%"></div></div><span class="match-pct">'+avg.toFixed(1)+'</span></div></td>';
    html += '<td style="color:var(--muted)">'+arr.length+'</td></tr>';
  });
  html += '</tbody></table>';
  inner.innerHTML = html;
}

// ── RADIO GROUPS ─────────────────────────────────────────────────────────
function buildRadioGroup(containerId, options, selectedVal, onChange) {
  var el = document.getElementById(containerId);
  var html = '<span class="radio-btn'+(selectedVal===''?' active':'') +'" onclick="radioSelect(\''+containerId+'\',\'\',this)">—</span>';
  options.forEach(function(opt) {
    html += '<span class="radio-btn'+(selectedVal===opt?' active':'') +'" onclick="radioSelect(\''+containerId+'\',\''+opt+'\',this)">'+opt+'</span>';
  });
  el.innerHTML = html;
}
function radioSelect(gid, val, el) {
  var parent = document.getElementById(gid);
  parent.querySelectorAll(".radio-btn").forEach(function(b){ b.classList.remove("active"); });
  el.classList.add("active");
}
function getRadioVal(containerId) {
  var parent = document.getElementById(containerId);
  var active = parent.querySelector(".radio-btn.active");
  if (!active) return "";
  return active.textContent === "—" ? "" : active.textContent;
}

