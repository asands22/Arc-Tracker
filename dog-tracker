function showDashboard() {
  document.getElementById("main-view").style.display = "block";
  document.getElementById("detail-view").style.display = "none";
  detailId = null;
}

function renderDetail(id) {
  var dog = DB.dogs.find(function(d){return d.id===id;});
  if (!dog) { showDashboard(); return; }
  var c = document.getElementById("detail-content");

  var html = "";
  // Header
  html += '<div class="detail-header">';
  html += '<div><div class="detail-name">'+esc(dog.name||"Dog")+'</div>';
  if (dog.breed) html += '<div class="detail-meta">'+esc(dog.breed)+(dog.age?' &middot; '+esc(dog.age):'')+(dog.sex?' &middot; '+esc(dog.sex):'')+'</div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px">';
  html += '<button class="btn btn-sm" onclick="openEditDog(\''+id+'\')">Edit</button>';
  html += '<button class="btn btn-primary btn-sm" onclick="openSessionModal(\''+id+'\')">+ Session Note</button>';
  html += '</div></div>';

  // Tab nav (rendered in HTML, controlled by JS)
  html += '<div class="tab-row">';
  html += '<button class="tab-btn active" id="tab-profile" onclick="switchTab(\'profile\')">Profile</button>';
  html += '<button class="tab-btn" id="tab-sessions" onclick="switchTab(\'sessions\')">Sessions ('+( (dog.sessions||[]).length)+')</button>';
  html += '<button class="tab-btn" id="tab-wins" onclick="switchTab(\'wins\')">Wins &amp; Risks</button>';
  html += '</div>';

  // TAB: PROFILE
  html += '<div id="tab-content-profile">';
  html += '<div class="detail-grid">';

  html += '<div class="detail-block"><div class="detail-block-title">Handler</div>';
  html += '<div class="detail-block-val">'+(dog.handler ? esc(dog.handler) : '<span style="color:var(--muted)">—</span>')+'</div></div>';

  html += '<div class="detail-block"><div class="detail-block-title">Profile</div>';
  html += '<div class="detail-block-val">'+(dog.profile ? '<span class="tag tag-profile">'+esc(dog.profile)+'</span>' : '<span style="color:var(--muted)">—</span>')+'</div></div>';

  html += '<div class="detail-block"><div class="detail-block-title">Program</div>';
  html += '<div class="detail-block-val">'+(dog.program ? esc(dog.program) : '<span style="color:var(--muted)">—</span>')+'</div></div>';

  html += '<div class="detail-block"><div class="detail-block-title">Match Score</div>';
  html += '<div class="detail-block-val">'+(dog.matchScore ? '<span style="color:var(--brass);font-family:Cinzel,serif;font-size:20px">'+esc(dog.matchScore)+'</span><span style="color:var(--muted);font-size:13px">/10</span>' : '<span style="color:var(--muted)">—</span>')+'</div></div>';

  html += '</div>'; // end detail-grid

  // Signature
  html += '<div style="margin-bottom:22px">';
  html += '<div class="detail-block-title">Handler Signature</div>';
  html += '<div class="sig-row">';
  if (dog.dominant) html += '<span class="sig-pill sig-dom">Dominant: '+esc(dog.dominant)+'</span>';
  if (dog.blind)    html += '<span class="sig-pill sig-blind">Blind: '+esc(dog.blind)+'</span>';
  if (dog.ghost)    html += '<span class="sig-pill sig-ghost">Ghost: '+esc(dog.ghost)+'</span>';
  if (!dog.dominant && !dog.blind && !dog.ghost) html += '<span style="color:var(--muted);font-size:14px">No signature recorded</span>';
  html += '</div></div>';

  // Why this dog
  if (dog.why) {
    html += '<div style="margin-bottom:18px">';
    html += '<div class="detail-block-title">Why This Dog</div>';
    html += '<div style="font-size:15px;color:var(--text);line-height:1.7;font-style:italic;font-family:\'EB Garamond\',serif">"'+esc(dog.why)+'"</div>';
    html += '</div>';
  }

  // Match notes
  if (dog.matchNotes) {
    html += '<div style="margin-bottom:18px">';
    html += '<div class="detail-block-title">Match Notes</div>';
    html += '<div style="font-size:14px;color:var(--text);line-height:1.7">'+esc(dog.matchNotes)+'</div>';
    html += '</div>';
  }

  // Trainer notes
  if (dog.notes) {
    html += '<div>';
    html += '<div class="detail-block-title">Trainer Notes</div>';
    html += '<div style="font-size:14px;color:var(--text);line-height:1.75">'+esc(dog.notes)+'</div>';
    html += '</div>';
  }

  html += '</div>'; // end tab-content-profile

  // TAB: SESSIONS
  html += '<div id="tab-content-sessions" style="display:none">';
  var sessions = dog.sessions || [];
  if (!sessions.length) {
    html += '<div class="empty"><div class="empty-title">No session notes yet</div><div class="empty-sub">Tap "+ Session Note" to start tracking</div></div>';
  } else {
    sessions.slice().reverse().forEach(function(s, idx) {
      html += '<div class="session-entry">';
      html += '<div style="display:flex;justify-content:space-between;align-items:center">';
      html += '<div class="session-date">'+(s.date||'')+(s.focus?' &mdash; '+esc(s.focus):'')+'</div>';
      html += '<button class="btn-icon" style="font-size:14px;color:var(--danger)" onclick="deleteSession(\''+id+'\',\''+s.id+'\')" title="Delete">&#10005;</button>';
      html += '</div>';
      if (s.channel) html += '<span class="tag tag-channel" style="margin-bottom:8px;display:inline-block">'+esc(s.channel)+'</span>';
      html += '<div class="session-text">'+esc(s.notes||"")+'</div>';
      html += '</div>';
    });
  }
  html += '</div>'; // end sessions

  // TAB: WINS & RISKS
  html += '<div id="tab-content-wins" style="display:none">';
  var wins  = dog.wins  || [];
  var risks = dog.risks || [];
  if (!wins.length && !risks.length) {
    html += '<div class="empty"><div class="empty-title">No wins or risks recorded</div><div class="empty-sub">Edit the dog record to add them</div></div>';
  } else {
    if (wins.length) {
      html += '<div class="detail-block-title" style="margin-bottom:10px">Wins</div><div class="wr-list" style="margin-bottom:20px">';
      wins.forEach(function(w){ html += '<div class="wr-item win"><span class="wr-icon">&#10003;</span>'+esc(w)+'</div>'; });
      html += '</div>';
    }
    if (risks.length) {
      html += '<div class="detail-block-title" style="margin-bottom:10px">Risks</div><div class="wr-list">';
      risks.forEach(function(r){ html += '<div class="wr-item risk"><span class="wr-icon">&#9651;</span>'+esc(r)+'</div>'; });
      html += '</div>';
    }
  }
  html += '</div>'; // end wins-risks

  c.innerHTML = html;
}

function switchTab(name) {
  ["profile","sessions","wins"].forEach(function(t) {
    var btn = document.getElementById("tab-"+t);
    var content = document.getElementById("tab-content-"+t);
    if (!btn || !content) return;
    if (t === name) {
      btn.classList.add("active");
      content.style.display = "block";
    } else {
      btn.classList.remove("active");
      content.style.display = "none";
    }
  });
}

function deleteSession(dogId, sessionId) {
  if (!confirm("Delete this session note?")) return;
  var dog = DB.dogs.find(function(d){return d.id===dogId;});
  if (!dog) return;
  dog.sessions = (dog.sessions||[]).filter(function(s){return s.id!==sessionId;});
  saveDB();
  renderDetail(dogId);
  renderDashboard();
  toast("Session note deleted");
}

// ── SESSION MODAL ─────────────────────────────────────────────────────────
function openSessionModal(dogId) {
  sessionTargetId = dogId;
  var today = new Date().toISOString().split("T")[0];
  document.getElementById("s-date").value = today;
  document.getElementById("s-focus").value = "";
  document.getElementById("s-notes").value = "";
  buildRadioGroup("s-channel-rg", CHANNELS, "", null);
  document.getElementById("session-modal").classList.add("open");
}

function closeSessionModal() {
  document.getElementById("session-modal").classList.remove("open");
  sessionTargetId = null;
}

function saveSession() {
  if (!sessionTargetId) return;
  var notes = document.getElementById("s-notes").value.trim();
  if (!notes) { toast("Notes required"); return; }
  var dog = DB.dogs.find(function(d){return d.id===sessionTargetId;});
  if (!dog) return;
  if (!dog.sessions) dog.sessions = [];
  dog.sessions.push({
    id:      Date.now().toString(),
    date:    document.getElementById("s-date").value,
    focus:   document.getElementById("s-focus").value.trim(),
    notes:   notes,
    channel: getRadioVal("s-channel-rg")
  });
  saveDB();
  closeSessionModal();
  renderDetail(sessionTargetId);
  renderDashboard();
  toast("Session note saved");
}

// ── EXPORT / IMPORT ───────────────────────────────────────────────────────
function exportData() {
  var a = document.createElement("a");
  var data = encodeURIComponent(JSON.stringify(DB, null, 2));
  a.setAttribute("href", "data:application/json;charset=utf-8,"+data);
  a.setAttribute("download", "shdt-dog-log-" + new Date().toISOString().split("T")[0] + ".json");
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
}

function importData(e) {
  var file = e.target.files[0];
  if (!file) return;
  var r = new FileReader();
  r.onload = function(ev) {
    try {
      DB = JSON.parse(ev.target.result);
      if (!DB.dogs) DB.dogs = [];
      saveDB();
      renderDashboard();
      toast("Import successful — " + DB.dogs.length + " dogs loaded");
    } catch(e) { toast("Invalid file"); }
  };
  r.readAsText(file);
  e.target.value = "";
}

// ── UTILS ─────────────────────────────────────────────────────────────────
function esc(str) {
  if (!str) return "";
  return String(str)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

function toast(msg) {
  var el = document.getElementById("toast");
  el.textContent = msg;
  el.classList.add("show");
  setTimeout(function(){ el.classList.remove("show"); }, 2800);
}

// ── BOOT ──────────────────────────────────────────────────────────────────
loadDB();
</script>

