// ── SAVE DOG ──────────────────────────────────────────────────────────────
function saveDog() {
  var name = document.getElementById("f-dog-name").value.trim();
  if (!name) { toast("Dog name required"); return; }

  var wins  = document.getElementById("f-wins").value.split("\n").map(function(s){return s.trim();}).filter(Boolean);
  var risks = document.getElementById("f-risks").value.split("\n").map(function(s){return s.trim();}).filter(Boolean);

  var dog = {
    id:         editingId || Date.now().toString(),
    name:       name,
    breed:      document.getElementById("f-breed").value.trim(),
    age:        document.getElementById("f-age").value.trim(),
    sex:        document.getElementById("f-sex").value,
    handler:    document.getElementById("f-handler").value.trim(),
    profile:    document.getElementById("f-profile").value,
    program:    document.getElementById("f-program").value,
    dominant:   getRadioVal("rg-dominant"),
    blind:      getRadioVal("rg-blind"),
    ghost:      getRadioVal("rg-ghost"),
    matchScore: document.getElementById("f-match-score").value,
    why:        document.getElementById("f-why").value.trim(),
    matchNotes: document.getElementById("f-match-notes").value.trim(),
    wins:       wins,
    risks:      risks,
    notes:      document.getElementById("f-notes").value.trim(),
    sessions:   [],
    created:    new Date().toISOString()
  };

  if (editingId) {
    var existing = DB.dogs.find(function(d){return d.id===editingId;});
    if (existing) {
      dog.sessions = existing.sessions || [];
      dog.created  = existing.created;
    }
    DB.dogs = DB.dogs.map(function(d){ return d.id===editingId ? dog : d; });
    toast("Dog updated");
  } else {
    DB.dogs.push(dog);
    toast("Dog logged");
  }

  saveDB();
  closeModal();
  renderDashboard();

  // If we're in detail view for this dog, refresh it
  if (detailId === dog.id) renderDetail(dog.id);
}

function deleteCurrentDog() {
  if (!editingId) return;
  var dog = DB.dogs.find(function(d){return d.id===editingId;});
  if (!dog) return;
  if (!confirm("Delete " + (dog.name||"this dog") + "? This cannot be undone.")) return;
  DB.dogs = DB.dogs.filter(function(d){return d.id!==editingId;});
  saveDB();
  closeModal();
  showDashboard();
  renderDashboard();
  toast("Dog deleted");
}

