<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SHDT — Dog Intelligence Log</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Cinzel+Decorative:wght@400;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Raleway:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #161610;
  --surface:   #1E1E16;
  --card:      #252519;
  --card2:     #2C2C1E;
  --olive:     #6F745C;
  --olive-lt:  #8A9070;
  --brass:     #C8A96E;
  --brass-dim: #9E7E48;
  --cream:     #D9D4C4;
  --muted:     #7A7260;
  --text:      #C4BFB0;
  --danger:    #B05A4A;
  --success:   #5A8060;
  --border:    rgba(200,169,110,0.15);
  --border-hi: rgba(200,169,110,0.45);
  --glow:      0 0 18px rgba(200,169,110,0.18);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
background: var(–bg);
color: var(–text);
font-family: ‘Raleway’, sans-serif;
font-size: 15px;
min-height: 100vh;
overflow-x: hidden;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(–bg); }
::-webkit-scrollbar-thumb { background: var(–olive); border-radius: 3px; }

/* ── TYPOGRAPHY ── */
.cinzel    { font-family: ‘Cinzel’, serif; }
.garamond  { font-family: ‘EB Garamond’, serif; }
.brass     { color: var(–brass); }
.muted     { color: var(–muted); }
.olive-txt { color: var(–olive-lt); }

/* ── LAYOUT ── */
.app { display: flex; flex-direction: column; min-height: 100vh; }

header {
border-bottom: 1px solid var(–border);
padding: 18px 28px;
display: flex;
align-items: center;
justify-content: space-between;
background: linear-gradient(180deg, rgba(200,169,110,0.04) 0%, transparent 100%);
position: sticky;
top: 0;
z-index: 100;
backdrop-filter: blur(8px);
}

.logo-block { display: flex; flex-direction: column; gap: 2px; }
.logo-title {
font-family: ‘Cinzel Decorative’, serif;
font-size: 17px;
color: var(–brass);
letter-spacing: 0.05em;
line-height: 1;
}
.logo-sub {
font-family: ‘Cinzel’, serif;
font-size: 11px;
color: var(–muted);
letter-spacing: 0.18em;
text-transform: uppercase;
}

.header-actions { display: flex; gap: 10px; align-items: center; }

main {
flex: 1;
padding: 28px;
max-width: 1300px;
width: 100%;
margin: 0 auto;
}

/* ── STAT TILES ── */
.stat-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
gap: 14px;
margin-bottom: 32px;
animation: fadeUp 0.5s ease both;
}

.stat-tile {
background: var(–card);
border: 1px solid var(–border);
border-radius: 6px;
padding: 18px 20px;
position: relative;
overflow: hidden;
transition: border-color 0.25s, box-shadow 0.25s;
cursor: default;
}
.stat-tile::before {
content: ‘’;
position: absolute;
bottom: 0; left: 0; right: 0;
height: 2px;
background: linear-gradient(90deg, transparent, var(–brass), transparent);
opacity: 0;
transition: opacity 0.3s;
}
.stat-tile:hover { border-color: var(–border-hi); box-shadow: var(–glow); }
.stat-tile:hover::before { opacity: 1; }
.stat-label {
font-family: ‘Cinzel’, serif;
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 10px;
}
.stat-value {
font-family: ‘Cinzel’, serif;
font-size: 32px;
font-weight: 700;
color: var(–brass);
line-height: 1;
}
.stat-detail {
font-size: 12px;
color: var(–muted);
margin-top: 6px;
}

/* ── SECTION PANEL ── */
.panel {
background: var(–card);
border: 1px solid var(–border);
border-radius: 6px;
margin-bottom: 18px;
overflow: hidden;
transition: box-shadow 0.25s;
animation: fadeUp 0.4s ease both;
}
.panel:hover { box-shadow: var(–glow); }

.panel-header {
display: flex;
align-items: center;
justify-content: space-between;
padding: 16px 22px;
cursor: pointer;
user-select: none;
transition: background 0.2s;
border-bottom: 1px solid transparent;
}
.panel-header:hover { background: rgba(200,169,110,0.04); }
.panel-header.open { border-bottom-color: var(–border); }

.panel-title-row { display: flex; align-items: center; gap: 12px; }
.panel-title {
font-family: ‘Cinzel’, serif;
font-size: 14px;
letter-spacing: 0.12em;
color: var(–cream);
}
.panel-count {
font-size: 11px;
background: rgba(200,169,110,0.12);
color: var(–brass);
border: 1px solid var(–border-hi);
border-radius: 10px;
padding: 2px 9px;
}

.chevron {
width: 18px;
height: 18px;
color: var(–brass-dim);
transition: transform 0.3s ease;
flex-shrink: 0;
}
.chevron.open { transform: rotate(180deg); }

.panel-body {
max-height: 0;
overflow: hidden;
transition: max-height 0.45s cubic-bezier(0.4,0,0.2,1);
}
.panel-body.open { max-height: 9000px; }
.panel-inner { padding: 22px; }

/* ── DOG CARDS ── */
.dog-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
gap: 16px;
}

.dog-card {
background: var(–card2);
border: 1px solid var(–border);
border-radius: 6px;
padding: 18px;
cursor: pointer;
transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
position: relative;
overflow: hidden;
}
.dog-card::after {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
background: var(–brass);
transform: scaleX(0);
transform-origin: left;
transition: transform 0.3s;
}
.dog-card:hover {
border-color: var(–border-hi);
transform: translateY(-2px);
box-shadow: 0 6px 24px rgba(0,0,0,0.4);
}
.dog-card:hover::after { transform: scaleX(1); }

.dog-name {
font-family: ‘Cinzel’, serif;
font-size: 16px;
color: var(–cream);
margin-bottom: 4px;
}
.dog-breed {
font-size: 13px;
color: var(–muted);
margin-bottom: 12px;
font-style: italic;
}
.dog-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
.tag {
font-size: 11px;
padding: 3px 9px;
border-radius: 3px;
font-family: ‘Cinzel’, serif;
letter-spacing: 0.05em;
}
.tag-channel { background: rgba(111,116,92,0.2); color: var(–olive-lt); border: 1px solid rgba(111,116,92,0.3); }
.tag-profile  { background: rgba(200,169,110,0.1); color: var(–brass); border: 1px solid var(–border-hi); }
.tag-match    { background: rgba(90,128,96,0.15); color: #7EB88A; border: 1px solid rgba(90,128,96,0.3); }
.tag-risk     { background: rgba(176,90,74,0.15); color: #D4806E; border: 1px solid rgba(176,90,74,0.3); }

.dog-handler {
font-size: 13px;
color: var(–muted);
border-top: 1px solid var(–border);
padding-top: 10px;
margin-top: 4px;
}

/* ── PATTERNS TABLE ── */
.pattern-table { width: 100%; border-collapse: collapse; }
.pattern-table th {
font-family: ‘Cinzel’, serif;
font-size: 11px;
letter-spacing: 0.15em;
color: var(–muted);
text-align: left;
padding: 10px 14px;
border-bottom: 1px solid var(–border);
font-weight: 400;
}
.pattern-table td {
padding: 12px 14px;
font-size: 14px;
border-bottom: 1px solid rgba(200,169,110,0.06);
vertical-align: middle;
}
.pattern-table tr:hover td { background: rgba(200,169,110,0.03); }

.match-bar-wrap { display: flex; align-items: center; gap: 10px; }
.match-bar-bg {
flex: 1;
height: 6px;
background: var(–card);
border-radius: 3px;
overflow: hidden;
}
.match-bar-fill {
height: 100%;
border-radius: 3px;
background: linear-gradient(90deg, var(–brass-dim), var(–brass));
transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
}
.match-pct {
font-family: ‘Cinzel’, serif;
font-size: 13px;
color: var(–brass);
min-width: 36px;
text-align: right;
}

/* ── MODAL ── */
.overlay {
position: fixed; inset: 0;
background: rgba(10,10,8,0.88);
z-index: 200;
display: flex; align-items: center; justify-content: center;
padding: 20px;
opacity: 0;
pointer-events: none;
transition: opacity 0.25s;
}
.overlay.open { opacity: 1; pointer-events: all; }

.modal {
background: var(–surface);
border: 1px solid var(–border-hi);
border-radius: 8px;
width: 100%;
max-width: 640px;
max-height: 90vh;
overflow-y: auto;
transform: translateY(20px);
transition: transform 0.3s ease;
box-shadow: 0 24px 80px rgba(0,0,0,0.6), var(–glow);
}
.overlay.open .modal { transform: translateY(0); }

.modal-header {
display: flex; align-items: center; justify-content: space-between;
padding: 20px 24px;
border-bottom: 1px solid var(–border);
position: sticky; top: 0;
background: var(–surface);
z-index: 1;
}
.modal-title {
font-family: ‘Cinzel’, serif;
font-size: 15px;
color: var(–brass);
letter-spacing: 0.1em;
}
.modal-body { padding: 24px; }

/* ── FORMS ── */
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-group.full { grid-column: 1 / -1; }
.form-label {
font-family: ‘Cinzel’, serif;
font-size: 11px;
letter-spacing: 0.15em;
color: var(–muted);
text-transform: uppercase;
}
.form-input, .form-select, .form-textarea {
background: var(–card);
border: 1px solid var(–border);
border-radius: 4px;
padding: 10px 13px;
font-family: ‘Raleway’, sans-serif;
font-size: 14px;
color: var(–cream);
outline: none;
transition: border-color 0.2s;
width: 100%;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
border-color: var(–brass-dim);
}
.form-textarea { resize: vertical; min-height: 80px; }
.form-select option { background: var(–card2); }

.form-section {
margin-top: 22px;
padding-top: 18px;
border-top: 1px solid var(–border);
}
.form-section-title {
font-family: ‘Cinzel’, serif;
font-size: 12px;
letter-spacing: 0.15em;
color: var(–brass);
text-transform: uppercase;
margin-bottom: 14px;
}

/* ── RADIO GROUP ── */
.radio-group { display: flex; flex-wrap: wrap; gap: 8px; }
.radio-btn {
display: flex; align-items: center; justify-content: center;
padding: 7px 14px;
border: 1px solid var(–border);
border-radius: 4px;
font-family: ‘Cinzel’, serif;
font-size: 12px;
color: var(–muted);
cursor: pointer;
transition: all 0.2s;
user-select: none;
background: var(–card);
}
.radio-btn:hover { border-color: var(–brass-dim); color: var(–cream); }
.radio-btn.active {
border-color: var(–brass);
color: var(–brass);
background: rgba(200,169,110,0.08);
}

/* ── BUTTONS ── */
.btn {
font-family: ‘Cinzel’, serif;
font-size: 13px;
letter-spacing: 0.1em;
padding: 10px 20px;
border: 1px solid var(–border);
border-radius: 4px;
cursor: pointer;
transition: all 0.2s;
background: transparent;
color: var(–text);
display: inline-flex; align-items: center; gap: 7px;
}
.btn:hover { border-color: var(–brass-dim); color: var(–brass); }
.btn-primary {
background: rgba(200,169,110,0.12);
border-color: var(–brass-dim);
color: var(–brass);
}
.btn-primary:hover { background: rgba(200,169,110,0.22); border-color: var(–brass); }
.btn-danger { border-color: rgba(176,90,74,0.4); color: #C47060; }
.btn-danger:hover { background: rgba(176,90,74,0.1); border-color: #B05A4A; }
.btn-sm { padding: 7px 14px; font-size: 11px; }
.btn-icon {
padding: 8px;
border: none;
background: transparent;
color: var(–muted);
cursor: pointer;
border-radius: 4px;
transition: color 0.2s;
font-size: 16px;
line-height: 1;
}
.btn-icon:hover { color: var(–brass); }

/* ── DETAIL VIEW ── */
.detail-header {
display: flex; align-items: flex-start; justify-content: space-between;
margin-bottom: 24px;
padding-bottom: 20px;
border-bottom: 1px solid var(–border);
}
.detail-name {
font-family: ‘Cinzel’, serif;
font-size: 24px;
color: var(–cream);
margin-bottom: 4px;
}
.detail-meta { font-size: 14px; color: var(–muted); }

.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
.detail-block { }
.detail-block-title {
font-family: ‘Cinzel’, serif;
font-size: 11px;
letter-spacing: 0.18em;
color: var(–brass);
text-transform: uppercase;
margin-bottom: 8px;
}
.detail-block-val { font-size: 15px; color: var(–cream); line-height: 1.6; }

.sig-row { display: flex; gap: 10px; margin-top: 8px; }
.sig-pill {
padding: 5px 14px;
border-radius: 3px;
font-family: ‘Cinzel’, serif;
font-size: 11px;
letter-spacing: 0.08em;
}
.sig-dom { background: rgba(200,169,110,0.15); color: var(–brass); border: 1px solid var(–border-hi); }
.sig-blind { background: rgba(176,90,74,0.12); color: #D4806E; border: 1px solid rgba(176,90,74,0.3); }
.sig-ghost { background: rgba(111,116,92,0.12); color: var(–olive-lt); border: 1px solid rgba(111,116,92,0.3); }

.session-entry {
background: var(–card2);
border: 1px solid var(–border);
border-radius: 5px;
padding: 14px 16px;
margin-bottom: 10px;
transition: border-color 0.2s;
}
.session-entry:hover { border-color: var(–border-hi); }
.session-date {
font-family: ‘Cinzel’, serif;
font-size: 11px;
color: var(–muted);
letter-spacing: 0.1em;
margin-bottom: 5px;
}
.session-text { font-size: 14px; color: var(–text); line-height: 1.65; }

.notice {
background: rgba(200,169,110,0.06);
border: 1px solid var(–border);
border-left: 3px solid var(–brass);
border-radius: 4px;
padding: 14px 18px;
font-size: 14px;
color: var(–muted);
line-height: 1.7;
margin-bottom: 20px;
}

/* ── EMPTY STATE ── */
.empty {
text-align: center;
padding: 48px 20px;
color: var(–muted);
}
.empty-icon { font-size: 40px; margin-bottom: 14px; opacity: 0.4; }
.empty-title {
font-family: ‘Cinzel’, serif;
font-size: 15px;
color: var(–muted);
margin-bottom: 6px;
}
.empty-sub { font-size: 13px; }

/* ── BACK NAV ── */
.back-btn {
display: inline-flex; align-items: center; gap: 7px;
font-family: ‘Cinzel’, serif;
font-size: 12px;
letter-spacing: 0.12em;
color: var(–muted);
cursor: pointer;
margin-bottom: 24px;
padding: 6px 0;
border: none;
background: transparent;
transition: color 0.2s;
text-transform: uppercase;
}
.back-btn:hover { color: var(–brass); }

/* ── DIVIDER ── */
.divider {
border: none;
border-top: 1px solid var(–border);
margin: 20px 0;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(12px); }
to   { opacity: 1; transform: translateY(0); }
}
@keyframes pulse-brass {
0%, 100% { box-shadow: 0 0 0 0 rgba(200,169,110,0); }
50%       { box-shadow: 0 0 0 6px rgba(200,169,110,0.12); }
}

.toast {
position: fixed;
bottom: 24px; right: 24px;
background: var(–card2);
border: 1px solid var(–border-hi);
border-radius: 5px;
padding: 12px 20px;
font-family: ‘Cinzel’, serif;
font-size: 13px;
color: var(–brass);
z-index: 999;
transform: translateY(80px);
opacity: 0;
transition: transform 0.3s ease, opacity 0.3s;
box-shadow: var(–glow);
}
.toast.show { transform: translateY(0); opacity: 1; }

/* ── DETAIL TABS ── */
.tab-row { display: flex; gap: 4px; margin-bottom: 22px; border-bottom: 1px solid var(–border); }
.tab-btn {
font-family: ‘Cinzel’, serif;
font-size: 12px;
letter-spacing: 0.12em;
color: var(–muted);
background: transparent;
border: none;
padding: 10px 18px;
cursor: pointer;
border-bottom: 2px solid transparent;
margin-bottom: -1px;
transition: color 0.2s, border-color 0.2s;
text-transform: uppercase;
}
.tab-btn:hover { color: var(–cream); }
.tab-btn.active { color: var(–brass); border-bottom-color: var(–brass); }

/* ── SCORE BAR ── */
.score-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.score-label { font-family: ‘Cinzel’, serif; font-size: 11px; color: var(–muted); min-width: 90px; letter-spacing: 0.08em; }
.score-track { flex: 1; height: 8px; background: var(–card); border-radius: 4px; overflow: hidden; }
.score-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(–brass-dim), var(–brass)); transition: width 0.5s ease; }
.score-num { font-family: ‘Cinzel’, serif; font-size: 13px; color: var(–brass); min-width: 28px; text-align: right; }

/* responsive */
@media (max-width: 640px) {
.form-grid { grid-template-columns: 1fr; }
.detail-grid { grid-template-columns: 1fr; }
main { padding: 16px; }
header { padding: 14px 16px; }
.stat-grid { grid-template-columns: repeat(2, 1fr); }
}

/* ── WIN/RISK PILLS ── */
.wr-list { display: flex; flex-direction: column; gap: 8px; }
.wr-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; border-radius: 4px; font-size: 14px; line-height: 1.5; }
.wr-item.win  { background: rgba(90,128,96,0.1); border: 1px solid rgba(90,128,96,0.25); color: #9FD0A8; }
.wr-item.risk { background: rgba(176,90,74,0.1); border: 1px solid rgba(176,90,74,0.25); color: #D4906E; }
.wr-icon { flex-shrink: 0; font-size: 15px; margin-top: 1px; }

.add-wr-row { display: flex; gap: 8px; margin-top: 10px; }
</style>

</head>
